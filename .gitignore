# ==========================================
# 🔐 Fichiers d'environnement et secrets
# ==========================================
.env
.env.local
.env.*.local
.env.*
!.env.example
!.env.example.*
!.env.global

# Secrets collectés
.env.*.backup
.env.*.bak

# ==========================================
# Services Node.js et Mix/Vite
# ==========================================
node_modules/
npm-debug.log
npm-debug.log.*
yarn-error.log
yarn-error.log.*
pointel-mobile/node_modules/

# ==========================================
# 📦 Dépendances PHP (Backend Laravel)
# ==========================================
vendor/
services/*/vendor/
services/*/composer.lock
services/auth-service/.env*
services/employee-service/.env*
services/pointage-service/.env*
services/notif-service/.env*
services/analytics-service/.env*

# ==========================================
# 📁 Caches et fichiers temporaires (Laravel)
# ==========================================
services/*/storage/logs/*
services/*/storage/framework/cache/*
services/*/storage/framework/sessions/*
services/*/storage/framework/views/*
services/*/bootstrap/cache/*
services/*/storage/work/*
services/*/storage/tmp/*
!services/*/storage/logs/.gitkeep
!services/*/storage/framework/cache/.gitkeep
!services/*/storage/framework/sessions/.gitkeep
!services/*/storage/framework/views/.gitkeep
!services/*/bootstrap/cache/.gitkeep

# ==========================================
# 🎨 Fichiers compilés et publics
# ==========================================
services/*/public/hot
services/*/public/storage
services/*/public/build/
services/*/public/mix-manifest.json
services/*/public/css/
services/*/public/js/
frontend/dist/
frontend/build/

# ==========================================
# 🗄️ Bases de données locales
# ==========================================
*.sqlite
*.sqlite3
*.db
services/*/database/*.sqlite
services/*/database/*.sqlite3
services/*/database/*.db
services/*/*_db
services/*/*_db-journal
auth_db
auth_db-journal
notif_db
pointage_db

# Dumps SQL
*.sql
*.sql.gz
dump.rdb

